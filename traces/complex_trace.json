  "output": {
    "type": "data",
    "content": "The total billed amount varies across departments, with the highest amount in the ENT department at 279535010.34 and the lowest in the Pediatrics department at 226406666.56, the total billed amount for each department is as follows: Cardiology is 232323720.08, Gastroenterology is 204080303.48, Urology is 276497946.08, and Pediatrics is 226406666.56",
    "sql": "SELECT T2.department_name, SUM(T1.total_amount) AS total_billed_amount FROM billing_invoices AS T1 INNER JOIN admissions AS T3 ON T1.admission_id = T3.admission_id INNER JOIN departments AS T2 ON T3.department_id = T2.department_id GROUP BY T2.department_name",
